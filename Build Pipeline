trigger: 
- main

stages: 
- stage: Build
  jobs:
  - job: Build
    pool:
        vmimage: ubuntu-latest
    steps:
    
    - task: Npm@1
      inputs:
        command: 'custom'
        customCommand: 'install -D tailwindcss postcss autoprefixer'

    - task: Npm@1
      inputs:
        command: 'custom'
        customCommand: 'run build'
        
    - task: Npm@1
      inputs:
        command: 'publish'
        workingDir: './dist'
        verbose: false
        publishRegistry: 'useFeed'
        publishFeed: ''
